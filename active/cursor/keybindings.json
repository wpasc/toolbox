// Place your key bindings in this file to override the defaults
[
    // Cmd+I: Cursor defaults this to inline chat, but agent mode is far more useful
    // as the primary AI interaction. Inline chat is still available via the menu.
    {
        "key": "cmd+i",
        "command": "composerMode.agent"
    },

    // Shift+Cmd+D: Go to definition. Mirrors NeoVim's gd muscle memory but in a
    // Mac-native chord. Shift+Cmd was chosen as the modifier pattern for all
    // code-navigation bindings (D=definition, R=references) to keep them consistent
    // and avoid conflicts with existing Cmd+D (add selection to next find match).
    {
        "key": "shift+cmd+d",
        "command": "editor.action.revealDefinition",
        "when": "editorTextFocus"
    },

    // Shift+Cmd+R: Find references (inline peek). Uses goToReferences for the
    // inline peek view (like Shift+F12) rather than references-view.findReferences
    // which opens the sidebar panel. Inline peek is faster for quick lookups.
    {
        "key": "shift+cmd+r",
        "command": "editor.action.goToReferences",
        "when": "editorTextFocus"
    },

    // Cmd+\: Split editor right. Matches Ghostty/tmux Cmd+\ for vertical split.
    // Consistent cross-tool muscle memory: same shortcut splits in both terminal and editor.
    {
        "key": "cmd+\\",
        "command": "workbench.action.splitEditor",
        "when": "editorTextFocus"
    },

    // Cmd+-: Split editor down. Matches Ghostty/tmux Cmd+- for horizontal split.
    // Overrides default Cmd+- (zoom out), which is rarely needed in an editor.
    {
        "key": "cmd+-",
        "command": "workbench.action.splitEditorDown",
        "when": "editorTextFocus"
    },

    // Cmd+1-9: Switch to tab by position (like browser tabs).
    // Overrides default "focus editor group" (focusFirstEditorGroup, etc.) which
    // creates new splits if the group doesn't exist — bad for a single-pane workflow.
    // Tab switching is the high-frequency action; split pane focus is occasional and
    // covered by Cmd+Option+Arrow. Cmd+number is prime real estate and should match
    // the most common use case.
    { "key": "cmd+1", "command": "workbench.action.openEditorAtIndex1" },
    { "key": "cmd+2", "command": "workbench.action.openEditorAtIndex2" },
    { "key": "cmd+3", "command": "workbench.action.openEditorAtIndex3" },
    { "key": "cmd+4", "command": "workbench.action.openEditorAtIndex4" },
    { "key": "cmd+5", "command": "workbench.action.openEditorAtIndex5" },
    { "key": "cmd+6", "command": "workbench.action.openEditorAtIndex6" },
    { "key": "cmd+7", "command": "workbench.action.openEditorAtIndex7" },
    { "key": "cmd+8", "command": "workbench.action.openEditorAtIndex8" },
    { "key": "cmd+9", "command": "workbench.action.openEditorAtIndex9" }
]
